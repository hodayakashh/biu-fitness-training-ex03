{
  "version": "1.00",
  "seed": 123,
  "data": {
    "seq_len": 7,
    "n_actions": 6,
    "state_dim": 5,
    "train_val_split": 0.8,
    "kaggle_dataset": "tejaswinimukesh/hevy-app-workout-dataset-from-dumbbells-to-data",
    "columns": {
      "date": "start_time",
      "sets": "_NO_SETS_COL_",
      "reps": "reps",
      "weight": "weight_lbs",
      "duration": "duration_seconds",
      "muscle_group": "muscle_group"
    },
    "muscle_groups": [
      "Chest",
      "Upper Back",
      "Lats",
      "Shoulders",
      "Biceps",
      "Triceps",
      "Quadriceps",
      "Hamstrings",
      "Glutes",
      "Calves",
      "Abdominals",
      "Lower Back",
      "Cardio",
      "Full Body",
      "Other"
    ]
  },
  "lstm": {
    "hidden_size": 64,
    "num_layers": 2,
    "dropout": 0.2,
    "action_embed_dim": 8,
    "learning_rate": 0.001,
    "batch_size": 64,
    "epochs": 50
  },
  "rl": {
    "episode_length": 28,
    "n_episodes": 500,
    "gamma": 0.99,
    "reinforce_lr": 0.0003,
    "actor_lr": 0.0003,
    "critic_lr": 0.001,
    "value_loss_coeff": 0.5,
    "entropy_bonus": 0.01
  },
  "reward": {
    "volume_target": 10000.0,
    "overload_threshold": 50000.0,
    "overload_threshold_norm": 0.8,
    "optimal_load_norm": 0.5,
    "lambda_overload": 0.4,
    "lambda_imbalance": 0.3,
    "lambda_repetition": 2.0,
    "variety_window": 7
  },
  "paths": {
    "data_dir": "data/",
    "results_dir": "results/",
    "plots_dir": "results/plots/",
    "lstm_weights": "results/lstm_weights.pt"
  }
}
